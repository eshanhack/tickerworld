{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "game-tickerworld.vercel.app" }],
      "destination": "https://tickerworld.io/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.tickerworld.io" }],
      "destination": "https://tickerworld.io/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), geolocation=(), microphone=(), payment=()" }
      ]
    },
    {
      "source": "/admin",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    },
    {
      "source": "/social/:card*",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400, stale-while-revalidate=604800" }]
    }
  ],
  "rewrites": [
    { "source": "/btc", "destination": "/btc.html" },
    { "source": "/eth", "destination": "/eth.html" },
    { "source": "/sol", "destination": "/sol.html" },
    { "source": "/xrp", "destination": "/xrp.html" },
    { "source": "/doge", "destination": "/doge.html" },
    { "source": "/bnb", "destination": "/bnb.html" },
    { "source": "/link", "destination": "/link.html" },
    { "source": "/avax", "destination": "/avax.html" },
    { "source": "/wti", "destination": "/wti.html" },
    { "source": "/test", "destination": "/test.html" },
    { "source": "/pump", "destination": "/pump.html" },
    { "source": "/ansem", "destination": "/ansem.html" },
    { "source": "/shfl", "destination": "/shfl.html" },
    { "source": "/skhynix", "destination": "/skhynix.html" },
    { "source": "/hype", "destination": "/hype.html" },
    { "source": "/xyz100", "destination": "/xyz100.html" },
    { "source": "/sp500", "destination": "/sp500.html" },
    { "source": "/micron", "destination": "/micron.html" },
    { "source": "/spacex", "destination": "/spacex.html" },
    { "source": "/nvidia", "destination": "/nvidia.html" },
    { "source": "/gold", "destination": "/gold.html" },
    { "source": "/apple", "destination": "/apple.html" },
    { "source": "/meta", "destination": "/meta.html" },
    { "source": "/google", "destination": "/google.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/privacy", "destination": "/privacy/index.html" },
    { "source": "/terms", "destination": "/terms/index.html" },
    { "source": "/community", "destination": "/community/index.html" },
    { "source": "/support", "destination": "/support/index.html" },
    { "source": "/status", "destination": "/status/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
