{
  "name": "tickerworld",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 4173 --strictPort",
    "build": "tsc -b && vite build && node scripts/generate-route-shells.mjs && node scripts/verify-release-assets.mjs",
    "preview": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:server": "npm --prefix server run build",
    "test:server": "npm --prefix server test",
    "test:all": "npm run test && npm run test:server",
    "audit:release": "npm audit --audit-level=high && npm --prefix server audit --audit-level=high",
    "verify:release": "npm run test:all && npm run build && npm run build:server && npm run audit:release",
    "smoke:production": "node scripts/smoke-production.mjs"
  },
  "dependencies": {
    "@colyseus/sdk": "^0.17.43",
    "@solana/client": "^1.7.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "three": "^0.179.1",
    "troika-three-text": "^0.52.4"
  },
  "devDependencies": {
    "@fontsource/nunito": "^5.2.7",
    "@types/three": "^0.179.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  }
}
