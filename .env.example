# The Vite client is served at http://127.0.0.1:4173 in local development.
# Point the browser at the local Colyseus service. This is a public Vite
# build-time value, never a secret. Canonical tickerworld.io pages automatically
# probe wss://us-lax-489a84b6.colyseus.cloud, so Production does not require this
# setting or a rebuild when that service becomes healthy. Preview should use an
# explicitly allowlisted server origin or remain unset for truthful solo mode.
VITE_MULTIPLAYER_URL=ws://127.0.0.1:2567

# Preview/local QA only. Leave unset in Production so ?data=sim, ?news=sim,
# and ?debug=1 cannot expose fictional launch content or debug controls.
VITE_ENABLE_QA_MODE=

# Vercel Functions read only the centralized multiplayer news cache. In Vercel
# Production set NEWS_CACHE_ORIGIN=https://us-lax-489a84b6.colyseus.cloud. This is a
# server-runtime value (no VITE_ prefix). Never configure X_BEARER_TOKEN in the
# Vercel client project; that paid credential belongs only on the room server.
NEWS_CACHE_ORIGIN=http://127.0.0.1:2567

# Optional production upgrade for DEX one-minute candle history. Without it,
# the cached Vercel function uses GeckoTerminal's keyless low-volume endpoint.
# This is server-only; never add a VITE_ prefix.
COINGECKO_PRO_API_KEY=
# Optional lower-tier CoinGecko Demo key; leave both keys empty to use the
# rate-limited keyless GeckoTerminal endpoint.
COINGECKO_DEMO_API_KEY=
