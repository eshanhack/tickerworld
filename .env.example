# The Vite client is served at http://127.0.0.1:4173 in local development.
# Point the browser at the local Colyseus service. Override this in Vercel with
# wss://multiplayer.tickerworld.io only after /healthz and /readyz are healthy.
VITE_MULTIPLAYER_URL=ws://127.0.0.1:2567

# Server-only. Create a paid X developer app and add its bearer token in Vercel.
# Never expose this through a VITE_-prefixed variable.
X_BEARER_TOKEN=
