NODE_ENV=development
PORT=2567
SQLITE_PATH=./data/tickerworld.sqlite
# Production requires DATABASE_URL and ignores SQLITE_PATH.
DATABASE_URL=
# Production requires this exact value. Disable only for local Postgres.
DATABASE_SSL=disable
# Comma-separated proxy CIDRs allowed to supply X-Forwarded-For. Empty is safest locally.
TRUSTED_PROXY_CIDRS=
# Local Vite origin. Production must be exactly https://tickerworld.io (plus an
# intentionally selected preview origin while smoke-testing), never a wildcard.
PUBLIC_ORIGIN=http://127.0.0.1:4173
SERVER_HMAC_SECRET=replace-with-at-least-32-random-characters
IP_HMAC_SECRET=replace-with-a-different-32-character-secret
TREASURY_ADDRESS=
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=
# Example: https://api.coingecko.com/api/v3/simple/price?ids=solana&vs_currencies=usd
SOL_USD_PRICE_URL=
ADMIN_WALLETS=
# Development-only deterministic quote authority; production deliberately rejects it.
DEV_SOL_USD_PRICE=
# Single-process launch caps and abuse controls.
MAX_PROCESS_CONNECTIONS=400
MAX_ROOMS=16
MAX_MARKET_SHARDS=8
MAX_CONCURRENT_PER_IP=20
ACTOR_JOINS_PER_MINUTE=12
IP_JOINS_PER_MINUTE=30
ANONYMOUS_SESSIONS_PER_MINUTE=10
AUTH_CHALLENGES_PER_MINUTE_IP=5
AUTH_CHALLENGES_PER_MINUTE_WALLET=5
PURCHASE_QUOTES_PER_HOUR=10
PURCHASE_CONFIRMS_PER_MINUTE=12
