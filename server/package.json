{
  "name": "tickerworld-multiplayer-server",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build:shared": "npm --prefix ../shared run build",
    "build": "npm run build:shared && tsc -p tsconfig.json",
    "dev": "npm run build:shared && tsx watch src/index.ts",
    "start": "node dist/index.js",
    "migrate": "node dist/db/runMigrations.js",
    "smoke:bot": "npm run build && node dist/smokeBot.js",
    "test": "npm run build:shared && vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@colyseus/schema": "4.0.27",
    "@colyseus/core": "0.17.44",
    "@colyseus/tools": "0.17.19",
    "@colyseus/ws-transport": "0.17.13",
    "@tickerworld/shared": "file:../shared",
    "better-sqlite3": "^12.11.1",
    "express": "5.2.1",
    "kysely": "0.29.3",
    "obscenity": "^0.4.6",
    "pg": "^8.22.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@colyseus/sdk": "0.17.43",
    "@colyseus/testing": "0.17.11",
    "@solana/client": "1.7.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^24.0.10",
    "@types/pg": "^8.15.5",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.4",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
